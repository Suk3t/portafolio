---
import { projects } from "../data/projects";

const { lang = "es", t } = Astro.props;
const items = projects[lang as "es" | "en"];
---

<section id="projects" class="projects-section">
    <div class="section-heading">
        <div>
            <span class="eyebrow">{t.projects.eyebrow}</span>
            <h2>{t.projects.title}</h2>
            <p>{t.projects.intro}</p>
        </div>

        <div class="carousel-controls" aria-label={t.projects.controls}>
            <button type="button" class="carousel-button" data-carousel-prev aria-label={t.projects.previous}>
                ←
            </button>
            <button type="button" class="carousel-button" data-carousel-next aria-label={t.projects.next}>
                →
            </button>
        </div>
    </div>

    <div class="projects-carousel" data-projects-carousel>
        {items.map((project, index) => (
            <article class="project-card">
                <button
                    type="button"
                    class="project-open"
                    data-project-open={`project-${index}`}
                    aria-haspopup="dialog"
                >
                    <div class="project-placeholder" style={`--project-accent: ${project.accent}`}>
                        <span>{String(index + 1).padStart(2, "0")}</span>
                        <strong>{project.title}</strong>
                    </div>

                    <div class="project-content">
                        <div class="project-title-row">
                            <h3>{project.title}</h3>
                            <span aria-hidden="true">↗</span>
                        </div>
                        <p>{project.summary}</p>
                        <ul class="tag-list" aria-label={t.projects.technologies}>
                            {project.technologies.map((technology) => <li>{technology}</li>)}
                        </ul>
                    </div>
                </button>
            </article>
        ))}
    </div>

    {items.map((project, index) => (
        <dialog class="project-dialog" id={`project-${index}`} aria-labelledby={`project-title-${index}`}>
            <div class="dialog-content">
                <button type="button" class="dialog-close" data-dialog-close aria-label={t.projects.close}>
                    ×
                </button>
                <div class="project-placeholder dialog-placeholder" style={`--project-accent: ${project.accent}`}>
                    <span>{String(index + 1).padStart(2, "0")}</span>
                    <strong>{project.title}</strong>
                </div>
                <span class="eyebrow">{t.projects.detail}</span>
                <h3 id={`project-title-${index}`}>{project.title}</h3>
                <p>{project.description}</p>
                <ul class="tag-list" aria-label={t.projects.technologies}>
                    {project.technologies.map((technology) => <li>{technology}</li>)}
                </ul>
                <a class="primary-link" href={project.github} target="_blank" rel="noopener noreferrer">
                    {t.projects.github}
                    <span aria-hidden="true">↗</span>
                </a>
            </div>
        </dialog>
    ))}
</section>

<script>
    const carousel = document.querySelector<HTMLElement>("[data-projects-carousel]");
    const previous = document.querySelector<HTMLButtonElement>("[data-carousel-prev]");
    const next = document.querySelector<HTMLButtonElement>("[data-carousel-next]");

    const scrollCarousel = (direction: number) => {
        if (!carousel) return;
        const card = carousel.querySelector<HTMLElement>(".project-card");
        carousel.scrollBy({ left: (card?.offsetWidth ?? 320) * direction, behavior: "smooth" });
    };

    previous?.addEventListener("click", () => scrollCarousel(-1));
    next?.addEventListener("click", () => scrollCarousel(1));

    document.querySelectorAll<HTMLButtonElement>("[data-project-open]").forEach((button) => {
        button.addEventListener("click", () => {
            const dialog = document.getElementById(button.dataset.projectOpen ?? "") as HTMLDialogElement | null;
            dialog?.showModal();
        });
    });

    document.querySelectorAll<HTMLDialogElement>(".project-dialog").forEach((dialog) => {
        dialog.querySelector<HTMLButtonElement>("[data-dialog-close]")?.addEventListener("click", () => dialog.close());
        dialog.addEventListener("click", (event) => {
            if (event.target === dialog) dialog.close();
        });
    });
</script>
