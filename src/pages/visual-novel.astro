---
import CompanyIcon from "../assets/company.svg";
import SchoolBackground from "../assets/visualnovel/bg/schoolMorning.webp";
import ShizukuDefault from "../assets/visualnovel/character/shizukuDefault.webp";
import ShizukuIcon from "../assets/visualnovel/character/icon.png";
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="theme-color" content="#24203c" />
        <title>Shizuku | Visual Novel</title>
    </head>
    <body>
        <main class="game-room">
            <div class="monitor">
                <div class="monitor-frame">
                    <div
                        class="visual-novel"
                        style={`--scene-background: url(${SchoolBackground.src})`}
                    >
                        <header class="novel-toolbar">
                            <img src={CompanyIcon.src} alt="" />
                            <a
                                class="novel-switch"
                                href="/"
                                role="switch"
                                aria-checked="false"
                                aria-label="Encender portafolio"
                                title="Volver al portafolio"
                            >
                                <span></span>
                            </a>
                            <p>Portfolio mode: OFF</p>
                        </header>

                        <div class="scene-vignette"></div>
                        <div class="scanlines"></div>

                        <img
                            class="character"
                            src={ShizukuDefault.src}
                            alt="Shizuku mirando al frente"
                        />

                        <section class="dialogue-panel" aria-label="Diálogo">
                            <div class="speaker">Shizuku</div>
                            <div class="speaker-portrait">
                                <img src={ShizukuIcon.src} alt="" />
                            </div>
                            <p>¿ senpai ?</p>
                            <span class="continue-indicator" aria-hidden="true"
                                >▼</span
                            >
                        </section>
                    </div>
                </div>
                <div class="monitor-controls" aria-hidden="true">
                    <span></span>
                    <span></span>
                </div>
                <div class="monitor-neck"></div>
                <div class="monitor-base"></div>
            </div>
        </main>
    </body>
</html>

<style>
    *,
    *::before,
    *::after {
        box-sizing: border-box;
    }

    * {
        margin: 0;
        padding: 0;
    }

    body {
        min-height: 100vh;
        background:
            radial-gradient(circle at 50% 35%, #45414e, #19171d 68%), #19171d;
        font-family: Georgia, "Times New Roman", serif;
    }

    .game-room {
        display: grid;
        place-items: center;
        min-height: 100svh;
        padding: 2rem;
        overflow: hidden;
    }

    .monitor {
        position: relative;
        width: min(82vw, calc(82vh * 4 / 3), 980px);
        padding: clamp(1rem, 2.4vw, 2rem) clamp(1rem, 2.4vw, 2rem)
            clamp(2.8rem, 5vw, 4.4rem);
        border: 3px solid #272328;
        border-radius: 2.2rem;
        background: linear-gradient(145deg, #b2aa91, #716b5d);
        box-shadow:
            inset 5px 5px 0 rgb(255 255 255 / 0.18),
            inset -6px -6px 0 rgb(35 31 29 / 0.28),
            0 35px 55px rgb(0 0 0 / 0.5);
    }

    .monitor-frame {
        position: relative;
        aspect-ratio: 4 / 3;
        padding: clamp(0.65rem, 1.4vw, 1.2rem);
        border: 3px solid #3c3733;
        border-radius: 1.7rem;
        background: #302c2a;
        box-shadow:
            inset 4px 4px 8px #161414,
            2px 2px 0 rgb(255 255 255 / 0.15);
    }

    .visual-novel {
        position: relative;
        width: 100%;
        height: 100%;
        overflow: hidden;
        isolation: isolate;
        border-radius: 1rem;
        background:
            linear-gradient(rgb(29 23 48 / 0.05), rgb(29 23 48 / 0.18)),
            var(--scene-background) center / cover no-repeat;
        box-shadow: inset 0 0 28px 10px rgb(12 10 17 / 0.6);
    }

    .monitor-controls {
        position: absolute;
        right: 2.4rem;
        bottom: 1rem;
        display: flex;
        gap: 0.55rem;
    }

    .monitor-controls span {
        width: 12px;
        height: 12px;
        border: 2px solid #49443c;
        border-radius: 50%;
        background: #e0804c;
        box-shadow: inset 1px 1px 2px rgb(255 255 255 / 0.4);
    }

    .monitor-controls span:last-child {
        background: #49443c;
    }

    .monitor-neck {
        position: absolute;
        right: 38%;
        bottom: -5.5rem;
        left: 38%;
        height: 5.7rem;
        border: 3px solid #272328;
        border-block-width: 0;
        background: linear-gradient(90deg, #777061, #aaa28b, #6c6659);
        z-index: -1;
    }

    .monitor-base {
        position: absolute;
        right: 24%;
        bottom: -7.2rem;
        left: 24%;
        height: 2.3rem;
        border: 3px solid #272328;
        border-radius: 50% 50% 0.8rem 0.8rem;
        background: linear-gradient(#aaa28b, #686257);
        box-shadow: 0 12px 20px rgb(0 0 0 / 0.35);
        z-index: -1;
    }

    .novel-toolbar {
        position: absolute;
        top: 0.65rem;
        left: 0.65rem;
        z-index: 5;
        display: flex;
        align-items: center;
        gap: 0.65rem;
        padding: 0.3rem 0.5rem;
        border: 2px solid rgb(255 255 255 / 0.75);
        border-radius: 0.3rem;
        background: rgb(31 25 52 / 0.82);
        box-shadow: 3px 3px 0 rgb(20 15 38 / 0.65);
        color: #fff;
    }

    .novel-toolbar img {
        width: 20px;
        height: 20px;
        filter: invert(1);
    }

    .novel-toolbar p {
        font:
            700 0.55rem/1 system-ui,
            sans-serif;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .novel-switch {
        position: relative;
        width: 34px;
        height: 18px;
        border: 2px solid #fff;
        border-radius: 999px;
        background: #403951;
    }

    .novel-switch span {
        position: absolute;
        top: 3px;
        left: 3px;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #d8d2e4;
        box-shadow: 1px 1px 0 rgb(0 0 0 / 0.4);
    }

    .scene-vignette {
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        background:
            linear-gradient(to bottom, rgb(18 13 32 / 0.2), transparent 25%),
            radial-gradient(circle, transparent 45%, rgb(15 10 28 / 0.42) 115%);
    }

    .scanlines {
        position: absolute;
        inset: 0;
        z-index: 6;
        pointer-events: none;
        background: repeating-linear-gradient(
            to bottom,
            transparent 0,
            transparent 2px,
            rgb(20 14 31 / 0.13) 3px
        );
        mix-blend-mode: multiply;
    }

    .character {
        position: absolute;
        z-index: 2;
        bottom: 0;
        left: 68%;
        width: 100%;
        max-width: none;
        height: auto;
        transform: translateX(-50%);
        filter: drop-shadow(0 12px 12px rgb(20 12 35 / 0.35));
    }

    .dialogue-panel {
        position: absolute;
        right: 4%;
        bottom: 4%;
        left: 4%;
        z-index: 4;
        min-height: 26%;
        padding: 6% 4% 3% 23%;
        border: 3px double #f5e9ff;
        background: linear-gradient(
            135deg,
            rgb(36 27 65 / 0.95),
            rgb(61 41 86 / 0.92)
        );
        box-shadow:
            0 0 0 3px rgb(35 22 55 / 0.82),
            8px 8px 0 rgb(20 12 35 / 0.42);
        color: #fff;
    }

    .dialogue-panel::before,
    .dialogue-panel::after {
        position: absolute;
        width: 22px;
        height: 22px;
        border: 2px solid #e8cff5;
        content: "";
        transform: rotate(45deg);
    }

    .dialogue-panel::before {
        top: 8px;
        right: 8px;
    }

    .dialogue-panel::after {
        bottom: 8px;
        left: 8px;
    }

    .speaker {
        position: absolute;
        top: -1.35rem;
        left: 21%;
        min-width: 130px;
        padding: 0.4rem 1rem;
        border: 3px double #f5e9ff;
        background: #6d4b84;
        box-shadow: 4px 4px 0 rgb(20 12 35 / 0.45);
        font-size: clamp(0.7rem, 1.4vw, 1rem);
        font-weight: 700;
        letter-spacing: 0.08em;
        text-align: center;
    }

    .speaker-portrait {
        position: absolute;
        top: 8%;
        bottom: 8%;
        left: 3%;
        width: 17%;
        height: 84%;
        overflow: hidden;
        border: 3px double #f5e9ff;
        background: #6d4b84;
        box-shadow: 4px 4px 0 rgb(20 12 35 / 0.45);
    }

    .speaker-portrait img {
        position: absolute;
        top: 78%;
        left: 50%;
        width: 350%;
        max-width: none;
        height: 300%;
        object-fit: fill;
        transform: translate(-50%, -43%);
    }

    .dialogue-panel p {
        font-size: clamp(0.8rem, 1.8vw, 1.35rem);
        line-height: 1.6;
        text-shadow: 2px 2px 0 rgb(0 0 0 / 0.45);
    }

    .continue-indicator {
        position: absolute;
        right: 1.4rem;
        bottom: 0.8rem;
        color: #f4d7ff;
        animation: continue 0.8s steps(2, end) infinite;
    }

    @keyframes continue {
        50% {
            transform: translateY(5px);
        }
    }

    @media (max-width: 650px) {
        .game-room {
            padding: 0.75rem 0.75rem 5rem;
        }

        .monitor {
            width: min(96vw, calc(78vh * 4 / 3));
            padding: 0.75rem 0.75rem 2.4rem;
            border-radius: 1.25rem;
        }

        .monitor-frame {
            padding: 0.45rem;
            border-radius: 1rem;
        }

        .novel-toolbar p {
            display: none;
        }

        .character {
            left: 70%;
            width: 112%;
        }

        .dialogue-panel {
            min-height: 29%;
            padding-left: 25%;
        }

        .speaker {
            top: -1rem;
            left: 22%;
            min-width: 90px;
            padding: 0.25rem 0.65rem;
        }

        .monitor-neck {
            bottom: -4.3rem;
            height: 4.5rem;
        }

        .monitor-base {
            bottom: -5.3rem;
            height: 1.6rem;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .continue-indicator {
            animation: none;
        }
    }
</style>
